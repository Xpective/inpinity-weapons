{
    "name": "inpinity-weapons",
    "version": "1.0.0",
    "private": true,
    "description": "Offchain metadata, assets, schemas and helper scripts for the Inpinity City weapon and crafting ecosystem.",
    "type": "module",
    "scripts": {
        "validate:weapons": "node scripts/validators/validate-weapons.mjs",
        "validate:components": "node scripts/validators/validate-components.mjs",
        "validate:blueprints": "node scripts/validators/validate-blueprints.mjs",
        "validate:enchantments": "node scripts/validators/validate-enchantments.mjs",
        "validate:enchantment-items": "node scripts/validators/validate-enchantment-items.mjs",
        "validate:materia": "node scripts/validators/validate-materia.mjs",
        "validate:materia-items": "node scripts/validators/validate-materia-items.mjs",
        "validate:recipes": "node scripts/validators/validate-recipes.mjs",
        "validate:metadata:weapons": "node scripts/validators/validate-metadata-weapons.mjs",
        "validate:metadata:components": "node scripts/validators/validate-metadata-components.mjs",
        "validate:metadata:blueprints": "node scripts/validators/validate-metadata-blueprints.mjs",
        "validate:metadata:enchantment-items": "node scripts/validators/validate-metadata-enchantment-items.mjs",
        "validate:metadata:materia-items": "node scripts/validators/validate-metadata-materia-items.mjs",
        "validate": "node scripts/validators/validate-all.mjs",
        "generate:all:auto": "node scripts/generators/generate-all-metadata.mjs --source=auto",
        "generate:all:auto:dry": "node scripts/generators/generate-all-metadata.mjs --dry-run --source=auto",
        "generate:components:auto": "node scripts/generators/generate-component-metadata.mjs --source=auto",
        "generate:blueprints:auto": "node scripts/generators/generate-blueprint-metadata.mjs --source=auto",
        "generate:enchantment-items:auto": "node scripts/generators/generate-enchantment-item-metadata.mjs --source=auto",
        "generate:materia-items:auto": "node scripts/generators/generate-materia-item-metadata.mjs --source=auto",
        "generate:weapons:auto": "node scripts/generators/generate-weapon-instance-metadata.mjs --source=auto",
        "scaffold": "node scripts/scaffold/scaffold.mjs",
        "sync": "node scripts/sync/sync-from-chain.mjs",
        "test:rarity-assets": "node scripts/lib/test-rarity-asset-resolver.mjs",
        "generate:weapons": "node scripts/generators/generate-weapon-instance-metadata.mjs",
        "generate:components": "node scripts/generators/generate-component-metadata.mjs",
        "generate:blueprints": "node scripts/generators/generate-blueprint-metadata.mjs",
        "generate:enchantment-items": "node scripts/generators/generate-enchantment-item-metadata.mjs",
        "generate:materia-items": "node scripts/generators/generate-materia-item-metadata.mjs",
        "previews:compose": "node scripts/previews/compose-all-previews.mjs --type=all",
        "previews:update-image-links": "node scripts/previews/update-metadata-image-links.mjs",
        "publish:prepare": "npm run previews:compose && npm run previews:update-image-links && npm run validate"
        
    },
    "keywords": [
        "inpinity",
        "city",
        "weapons",
        "metadata",
        "assets",
        "erc721",
        "erc1155",
        "crafting",
        "base"
    ],
    "author": "Xpective / Inpinity",
    "license": "MIT",
    "dependencies": {
        "ajv": "^8.17.1",
        "ajv-formats": "^3.0.1",
        "fast-glob": "^3.3.3",
        "sharp": "^0.34.5",
        "viem": "^2.47.4"
    }
}
