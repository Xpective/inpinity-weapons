{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://assets.inpinity.online/city/schemas/materia-item-metadata.schema.json",
  "title": "Materia Item Metadata Schema",
  "description": "Schema for published ERC1155 materia item metadata aligned to live CityMateriaItems definitions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "tokenStandard",
    "network",
    "chainId",
    "contractAddress",
    "materiaItemDefinitionId",
    "materiaDefinitionId",
    "name",
    "description",
    "image",
    "external_url",
    "attributes",
    "verificationStatus",
    "rarityPresentation"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "minLength": 1 },
    "kind": { "const": "materiaItemMetadata" },
    "tokenStandard": { "const": "ERC1155" },
    "network": { "type": "string", "minLength": 1 },
    "chainId": { "type": "integer", "minimum": 1 },
    "contractAddress": {
      "$ref": "common.schema.json#/$defs/hexAddress"
    },
    "materiaItemDefinitionId": {
      "type": "integer",
      "minimum": 1,
      "maximum": 999
    },
    "materiaDefinitionId": {
      "type": "integer",
      "minimum": 1,
      "maximum": 999
    },
    "name": {
      "$ref": "common.schema.json#/$defs/nameString"
    },
    "description": {
      "$ref": "common.schema.json#/$defs/longString"
    },
    "image": {
      "$ref": "common.schema.json#/$defs/uriString"
    },
    "external_url": {
      "$ref": "common.schema.json#/$defs/uriString"
    },
    "attributes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "common.schema.json#/$defs/attributeObject"
      }
    },
    "media": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/mediaObject"
      }
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sourceContract": {
      "$ref": "common.schema.json#/$defs/hexAddress"
    },
    "sourceReadMethod": {
      "type": "string",
      "minLength": 1
    },
    "sourceMode": {
      "type": "string",
      "enum": ["chain", "definitions", "auto"]
    },
    "sourceFallbackReason": {
      "type": "string"
    },
    "verificationStatus": {
      "$ref": "common.schema.json#/$defs/verificationStatus"
    },
    "notes": {
      "type": "string",
      "maxLength": 2000
    },
    "rarityPresentation": {
      "$ref": "common.schema.json#/$defs/rarityPresentationObject"
    }
  }
}