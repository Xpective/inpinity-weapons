{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://assets.inpinity.online/city/schemas/common.schema.json",
  "title": "Inpinity City Common Schema",
  "description": "Common reusable schema definitions for offchain Inpinity City metadata.",
  "$defs": {
    "nonNegativeInteger": {
      "type": "integer",
      "minimum": 0
    },
    "positiveInteger": {
      "type": "integer",
      "minimum": 1
    },
    "booleanFlag": {
      "type": "boolean"
    },
    "nameString": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "shortString": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "longString": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "uriString": {
      "type": "string",
      "minLength": 1
    },
    "slugString": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "hexAddress": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$"
    },
    "hex32": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$"
    },
    "metadataRevision": {
      "type": "integer",
      "minimum": 1
    },
    "verificationStatus": {
      "type": "string",
      "enum": [
        "confirmed",
        "derived",
        "unverified"
      ]
    },
    "displayTierObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 0
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        }
      }
    },
    "resourceCostLine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resourceId",
        "amount"
      ],
      "properties": {
        "resourceId": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9
        },
        "amount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "resourceCostsRaw": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "integer",
        "minimum": 0
      }
    },
    "mediaObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "uri"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "image",
            "thumbnail",
            "icon",
            "frame",
            "render",
            "video"
          ]
        },
        "uri": {
          "$ref": "#/$defs/uriString"
        },
        "mimeType": {
          "type": "string"
        },
        "width": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "height": {
          "$ref": "#/$defs/nonNegativeInteger"
        },
        "label": {
          "type": "string",
          "maxLength": 120
        }
      }
    },
    "attributeObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trait_type",
        "value"
      ],
      "properties": {
        "trait_type": {
          "type": "string",
          "minLength": 1
        },
        "value": {},
        "display_type": {
          "type": "string",
          "enum": [
            "number",
            "boost_number",
            "boost_percentage",
            "date",
            "string"
          ]
        }
      }
    },
    "bonusLevelEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "values"
      ],
      "properties": {
        "level": {
          "type": "integer",
          "minimum": 1
        },
        "values": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "rarityPresentationObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rarityTier",
        "key",
        "name",
        "frame",
        "background"
      ],
      "properties": {
        "rarityTier": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "key": {
          "type": "string",
          "enum": [
            "common",
            "rare",
            "epic",
            "legendary",
            "mythic"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "frame": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path512",
            "publicUrl",
            "transparentCenter",
            "masterSize"
          ],
          "properties": {
            "path512": {
              "type": "string",
              "minLength": 1
            },
            "publicUrl": {
              "$ref": "#/$defs/uriString"
            },
            "transparentCenter": {
              "type": "boolean"
            },
            "masterSize": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "background": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path512",
            "publicUrl",
            "masterSize"
          ],
          "properties": {
            "path512": {
              "type": "string",
              "minLength": 1
            },
            "publicUrl": {
              "$ref": "#/$defs/uriString"
            },
            "masterSize": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    }
  }
}