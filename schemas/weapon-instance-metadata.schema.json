{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://assets.inpinity.online/city/schemas/weapon-instance-metadata.schema.json",
  "title": "Weapon Instance Metadata Schema",
  "description": "Schema for published ERC721 weapon metadata aligned to live CityWeapons instances.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "tokenStandard",
    "network",
    "chainId",
    "contractAddress",
    "tokenId",
    "weaponDefinitionId",
    "name",
    "description",
    "owner",
    "weaponClass",
    "damageType",
    "rarityTier",
    "frameTier",
    "durability",
    "upgradeLevel",
    "metadataRevision",
    "originPlotId",
    "originFaction",
    "originDistrictKind",
    "craftedAt",
    "visualVariant",
    "resonanceType",
    "craftSeed",
    "provenanceHash",
    "genesisEra",
    "usedAether",
    "image",
    "external_url",
    "attributes",
    "verificationStatus",
    "rarityPresentation"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "const": "weaponInstance"
    },
    "tokenStandard": {
      "const": "ERC721"
    },
    "network": {
      "type": "string",
      "minLength": 1
    },
    "chainId": {
      "type": "integer",
      "minimum": 1
    },
    "contractAddress": {
      "$ref": "common.schema.json#/$defs/hexAddress"
    },
    "tokenId": {
      "type": "integer",
      "minimum": 1
    },
    "weaponDefinitionId": {
      "type": "integer",
      "minimum": 1,
      "maximum": 999
    },
    "name": {
      "$ref": "common.schema.json#/$defs/nameString"
    },
    "description": {
      "$ref": "common.schema.json#/$defs/longString"
    },
    "owner": {
      "$ref": "common.schema.json#/$defs/hexAddress"
    },
    "weaponClass": {
      "type": "integer",
      "minimum": 0,
      "maximum": 14
    },
    "damageType": {
      "type": "integer",
      "minimum": 0,
      "maximum": 12
    },
    "rarityTier": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "frameTier": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "durability": {
      "type": "integer",
      "minimum": 0
    },
    "upgradeLevel": {
      "type": "integer",
      "minimum": 0
    },
    "metadataRevision": {
      "$ref": "common.schema.json#/$defs/metadataRevision"
    },
    "originPlotId": {
      "type": "integer",
      "minimum": 0
    },
    "originFaction": {
      "type": "integer",
      "minimum": 0
    },
    "originDistrictKind": {
      "type": "integer",
      "minimum": 0
    },
    "craftedAt": {
      "type": "integer",
      "minimum": 0
    },
    "visualVariant": {
      "type": "integer",
      "minimum": 0
    },
    "resonanceType": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3
    },
    "craftSeed": {
      "$ref": "common.schema.json#/$defs/hex32"
    },
    "provenanceHash": {
      "$ref": "common.schema.json#/$defs/hex32"
    },
    "genesisEra": {
      "type": "boolean"
    },
    "usedAether": {
      "type": "boolean"
    },
    "image": {
      "$ref": "common.schema.json#/$defs/uriString"
    },
    "external_url": {
      "$ref": "common.schema.json#/$defs/uriString"
    },
    "attributes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "common.schema.json#/$defs/attributeObject"
      }
    },
    "media": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/mediaObject"
      }
    },
    "composition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "recipeId", "intendedComponents", "notes"],
      "properties": {
        "type": {
          "type": "string"
        },
        "recipeId": {
          "type": "integer",
          "minimum": 1
        },
        "intendedComponents": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["componentDefinitionId", "name"],
            "properties": {
              "componentDefinitionId": {
                "type": "integer",
                "minimum": 1,
                "maximum": 999
              },
              "name": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "notes": {
          "type": "string",
          "maxLength": 2000
        }
      }
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sourceContract": {
      "$ref": "common.schema.json#/$defs/hexAddress"
    },
    "sourceReadMethod": {
      "type": "string",
      "minLength": 1
    },
    "sourceMode": {
      "type": "string",
      "enum": ["chain", "definitions", "auto"]
    },
    "sourceFallbackReason": {
      "type": "string"
    },
    "verificationStatus": {
      "$ref": "common.schema.json#/$defs/verificationStatus"
    },
    "notes": {
      "type": "string",
      "maxLength": 2000
    },
    "display": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "weaponClassLabel": { "type": "string" },
        "damageTypeLabel": { "type": "string" },
        "rarityLabel": { "type": "string" },
        "frameTierLabel": { "type": "string" },
        "originFactionLabel": { "type": "string" },
        "resonanceTypeLabel": { "type": "string" }
      }
    },
    "rarityPresentation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rarityTier", "key", "name", "frame", "background"],
      "properties": {
        "rarityTier": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "key": {
          "type": "string",
          "enum": ["common", "rare", "epic", "legendary", "mythic"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "frame": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path512", "publicUrl", "transparentCenter", "masterSize"],
          "properties": {
            "path512": {
              "type": "string",
              "minLength": 1
            },
            "publicUrl": {
              "$ref": "common.schema.json#/$defs/uriString"
            },
            "transparentCenter": {
              "type": "boolean"
            },
            "masterSize": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "background": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path512", "publicUrl", "masterSize"],
          "properties": {
            "path512": {
              "type": "string",
              "minLength": 1
            },
            "publicUrl": {
              "$ref": "common.schema.json#/$defs/uriString"
            },
            "masterSize": {
              "type": "integer",
              "minimum": 1
            }
          }
        }
      }
    }
  }
}