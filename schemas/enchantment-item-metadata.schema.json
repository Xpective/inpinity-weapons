{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://assets.inpinity.online/city/schemas/enchantment-item-metadata.schema.json",
    "title": "Enchantment Item Metadata Schema",
    "description": "Schema for published ERC1155 enchantment item metadata aligned to live CityEnchantmentItems definitions.",
    "type": "object",
    "additionalProperties": false,
    "required": [
      "schemaVersion",
      "kind",
      "tokenStandard",
      "network",
      "chainId",
      "contractAddress",
      "enchantmentItemDefinitionId",
      "enchantmentDefinitionId",
      "name",
      "description",
      "image",
      "external_url",
      "attributes",
      "verificationStatus"
    ],
    "properties": {
      "schemaVersion": { "type": "string", "minLength": 1 },
      "kind": { "const": "enchantmentItemMetadata" },
      "tokenStandard": { "const": "ERC1155" },
      "network": { "type": "string", "minLength": 1 },
      "chainId": { "type": "integer", "minimum": 1 },
      "contractAddress": {
        "$ref": "common.schema.json#/$defs/hexAddress"
      },
      "enchantmentItemDefinitionId": {
        "type": "integer",
        "minimum": 1,
        "maximum": 999
      },
      "enchantmentDefinitionId": {
        "type": "integer",
        "minimum": 1,
        "maximum": 999
      },
      "name": {
        "$ref": "common.schema.json#/$defs/nameString"
      },
      "description": {
        "$ref": "common.schema.json#/$defs/longString"
      },
      "image": {
        "$ref": "common.schema.json#/$defs/uriString"
      },
      "external_url": {
        "$ref": "common.schema.json#/$defs/uriString"
      },
      "attributes": {
        "type": "array",
        "minItems": 1,
        "items": {
          "$ref": "common.schema.json#/$defs/attributeObject"
        }
      },
      "media": {
        "type": "array",
        "items": {
          "$ref": "common.schema.json#/$defs/mediaObject"
        }
      },
      "verificationStatus": {
        "$ref": "common.schema.json#/$defs/verificationStatus"
      },
      "notes": {
        "type": "string",
        "maxLength": 2000
      }
    }
  }